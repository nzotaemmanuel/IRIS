# Express Server Port
PORT=3000

# Database Selection: 'LOCAL' or 'AZURE'
DB_TYPE=LOCAL

# Local Database Settings
DB_SERVER_LOCAL=localhost
DB_NAME_LOCAL=LASIMRA_IRIS
DB_USER_LOCAL=sa
DB_PASS_LOCAL=your_password
DB_ENCRYPT_LOCAL=false
DB_TRUST_CERT_LOCAL=true
DB_PORT_LOCAL=1433

# Azure Database Settings (Template)
#DB_SERVER_AZURE=your-server.database.windows.net
#DB_NAME_AZURE=LASIMRA_IRIS
#DB_USER_AZURE=sql-username
#DB_PASS_AZURE=sql-password
#DB_ENCRYPT_AZURE=true
#DB_TRUST_CERT_AZURE=false
#DB_PORT_AZURE=1433

# JWT Settings
JWT_ACCESS_SECRET=super_secret_temporary_key_change_in_production
JWT_REFRESH_SECRET=another_secret_temporary_key_change_in_production
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=24h
